lor: var(--fg-2);\n}\n\n/* Utility: page reset for design-system previews */\nhtml.dcamp-preview, body.dcamp-preview {\n  background: var(--bg-page);\n  color: var(--fg-1);\n  font-family: var(--font-sans);\n  -webkit-font-smoothing: antialiased;\n  margin: 0;\n}\n<\u002Fstyle>\n<style>/* ── 그로스팀 인물 퀴즈 · 페이지 스타일 ── */\n\n:root {\n  /* tweak-driven */\n  --accent: var(--dcamp-orange);\n  --page-bg: var(--dcamp-white);\n}\n\n* { box-sizing: border-box; }\n\nhtml { scroll-behavior: smooth; }\n\nbody {\n  margin: 0;\n  background: var(--page-bg);\n  color: var(--fg-1);\n  font-family: var(--font-sans);\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility;\n}\n\n#root { width: 100%; }\n\n/* shared layout */\n.gx-wrap { max-width: 1000px; margin: 0 auto; padding: 0 32px; }\n\n/* fixed top chrome */\n.gx-topbar {\n  position: fixed; top: 0; left: 0; right: 0; z-index: 40;\n  height: 64px;\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 0 28px;\n  background: color-mix(in srgb, var(--page-bg) 82%, transparent);\n  border-bottom: 1px solid var(--border-soft);\n}\n.gx-topbar img { height: 18px; display: block; }\n.gx-progresspill {\n  display: flex; align-items: center; gap: 10px;\n  font-family: var(--font-display); font-weight: 600; font-size: 13px;\n  letter-spacing: 0.02em; color: var(--fg-2);\n}\n.gx-progresstrack { width: 120px; height: 6px; border-radius: 999px; background: var(--dcamp-gray-200); overflow: hidden; }\n.gx-progressfill { height: 100%; background: var(--accent); border-radius: 999px; transition: width 320ms var(--ease-out); }\n\n/* section rhythm */\n.gx-section { padding: 96px 0; }\n.gx-section:first-of-type { padding-top: 128px; }\n\n/* eyebrow */\n.gx-eyebrow {\n  font-family: var(--font-display); font-weight: 600; font-size: 13px;\n  text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent);\n}\n\n/* keyframes */\n@keyframes gx-rise {\n  from { transform: translateY(18px); }\n  to   { transform: translateY(0); }\n}\n@keyframes gx-pop {\n  0%   { opacity: 0; transform: scale(0.92); }\n  60%  { opacity: 1; transform: scale(1.02); }\n  100% { opacity: 1; transform: scale(1); }\n}\n@keyframes gx-stamp {\n  0%   { opacity: 0; transform: rotate(-14deg) scale(1.6); }\n  55%  { opacity: 1; transform: rotate(-14deg) scale(0.92); }\n  100% { opacity: 1; transform: rotate(-14deg) scale(1); }\n}\n@keyframes gx-fadein { from { opacity: 0; } to { opacity: 1; } }\n\n/* reveal-on-scroll — transform-only so content is never hidden if JS/anim is paused */\n.gx-reveal { opacity: 1; }\n.gx-reveal.gx-in { animation: gx-rise 560ms var(--ease-out) both; }\n\n@media (prefers-reduced-motion: reduce) {\n  html { scroll-behavior: auto; }\n  .gx-reveal { animation: none !important; transform: none !important; }\n}\n\n/* lucide icon sizing */\n.gx-ic { display: inline-flex; align-items: center; justify-content: center; }\n.gx-ic svg { width: 1em; height: 1em; stroke-width: 2; }\n\n/* fullscreen button */\n.gx-fsbtn:hover { background: var(--dcamp-ink) !important; color: #fff !important; border-color: var(--dcamp-ink) !important; }\n.gx-fsbtn:active { transform: scale(0.98); }\n\n/* selection */\n::selection { background: var(--dcamp-orange-soft); color: var(--dcamp-ink); }\n<\u002Fstyle>\n<style>/* devanagari */\n@font-face {\n  font-family: 'Poppins';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"1fb84893-d633-4da7-8061-d51d0d21f692\") format('woff2');\n  unicode-range: U+0900-097F, U+1CD0-1CF9, U+200C-200D, U+20A8, U+20B9, U+20F0, U+25CC, U+A830-A839, U+A8E0-A8FF, U+11B00-11B09;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Poppins';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"fa9d022c-6432-4743-88d9-6f8a3e9c789b\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0